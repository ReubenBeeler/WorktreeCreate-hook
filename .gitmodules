# These submodules are local-only test fixtures.
# The URLs below are placeholders; setup-test-fixtures.sh writes the real
# absolute path into .git/config (which overrides .gitmodules at runtime).
[submodule "submodules/alpha"]
	path = submodules/alpha
	url = .claude/test-upstreams/alpha.git
[submodule "submodules/beta"]
	path = submodules/beta
	url = .claude/test-upstreams/beta.git
